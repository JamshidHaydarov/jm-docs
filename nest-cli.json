{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "../templates/**/*",
        "outDir": "dist/templates"
      },
      {
        "include": "../static/**/*",
        "outDir": "dist/static"
      }
    ],
    "watchAssets": true,
    "deleteOutDir": true
  }
}
